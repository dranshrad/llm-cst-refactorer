# Copy to .env and fill in values as needed.
# Never commit real secrets.

# Engine: anthropic | openai | compatible
LLM_CST_ENGINE=anthropic

# Model override (optional)
# LLM_CST_MODEL=claude-sonnet-5
# LLM_CST_MODEL=gpt-5-mini

# Provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OpenAI-compatible endpoint (Ollama, vLLM, LocalAI, etc.)
# LLM_CST_BASE_URL=http://localhost:11434/v1
# For compatible engines without auth, any non-empty key often works:
# OPENAI_API_KEY=ollama
